    given-names: "John Garman"
    name: "John Garman Van Geem"
    orcid: "https://orcid.org/0009-0002-4003-8452"
    affiliation: "CEO / RQM Technologies"
keywords:
  - riemann-hypothesis
  - zeta-function
  - analytic-number-theory
  - balance-functional-method
  - spectral-theory
  - manuscript-under-review
  - mathematical-audit
